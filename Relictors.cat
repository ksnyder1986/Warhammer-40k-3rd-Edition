  <sharedSelectionEntries>
    <selectionEntry type="upgrade" import="true" name="Daemon Weapon Bearer" hidden="false" id="28d1-a744-06b4-46e7">
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="260d-d997-0a95-24ea" includeChildSelections="true"/>
      </constraints>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="25"/>
      </costs>
      <rules>
        <rule name="Relictor Deamon Weapon" id="a45e-3bfa-3578-c0e2" hidden="false">
          <description>Roll a D6 before the game begins to determine which type of weapon the bearer carries.
1 - Dark Blade
2 - Dreadaxe
3 - Axe of Khorne
4 - Pandemic Staff
5 - Needle of Desire
6 - Warp Blade</description>
        </rule>
      </rules>
      <infoGroups>
        <infoGroup name="Relictor Daemon Weapon Profiles" id="70fa-a278-0e0a-fb47" hidden="false">
          <profiles>
            <profile name="Axe of Khorne" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon" hidden="false" id="33f0-7a93-c58f-dd20">
              <characteristics>
                <characteristic name="Range" typeId="deb8-131d-bdcf-1376">Melee</characteristic>
                <characteristic name="S" typeId="24d8-2110-08fa-d844">As User</characteristic>
                <characteristic name="AP" typeId="25ce-028f-0aae-2855">1</characteristic>
                <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Melee</characteristic>
                <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Ignore armour saves. Hit rolls of 6 allow an additional attack. The new attack makes a new attack on a 6, and so on.</characteristic>
              </characteristics>
            </profile>
            <profile name="Dark Blade" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon" hidden="false" id="9a29-7103-c910-9477">
              <characteristics>

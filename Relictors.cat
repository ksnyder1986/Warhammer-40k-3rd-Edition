    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Chaos Relic" hidden="false" id="cea6-461f-9a78-4c1c">
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="50"/>
      </costs>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="0eec-eeaf-3921-3ea9" includeChildSelections="true"/>
      </constraints>
      <rules>
        <rule name="Blasted Standard" id="c9da-390c-92c1-81a1" hidden="false">
          <description>Once per battle in the player&apos;s Shooting Phase the standard can be aimed at any enemy unit with a model with 6&quot; of the Icon Bearer and may even target a unit in close combat. The spell inflicts 2D6 S6 AP4 hits.</description>
        </rule>
        <rule name="Banner of Rage" id="aa20-e2f4-4346-7617" hidden="false">
          <description>Once per battle release its power. In any Assault phase the models in the same unit as the model bearing the Banner gain +1 A.</description>
        </rule>
        <rule name="Plague Banner" id="331a-8db1-aaa9-d6b4" hidden="false">
          <description>Once per battle cause any one enemy unit within 6&quot; to take D6 wounds with no armour or cover saves possible.</description>
        </rule>
        <rule name="Rapturous Standard" id="704b-f597-3c54-0bee" hidden="false">
          <description>Once per game at the start of the Shooting Phase any model within 6&quot; gains the Feel no Pain special ability for the remainder of the turn.</description>
        </rule>
        <rule name="Icon of Chaos Undivided" id="31ac-17e5-4625-25a5" hidden="false">
          <description>Any unit or model 6&quot; becomes Fearless.</description>
        </rule>
      </rules>
    </selectionEntry>
  </sharedSelectionEntries>
</catalogue>

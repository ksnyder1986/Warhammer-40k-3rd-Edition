                <characteristic name="Sv" typeId="b309-5233-122f-82bb">2+</characteristic>
              </characteristics>
            </profile>
            <profile name="Cinder&apos;s Edge" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon" hidden="false" id="2ab6-b718-70e6-9003">
              <characteristics>
                <characteristic name="Range" typeId="deb8-131d-bdcf-1376">Melee</characteristic>
                <characteristic name="S" typeId="24d8-2110-08fa-d844">User</characteristic>
                <characteristic name="AP" typeId="25ce-028f-0aae-2855">2</characteristic>
                <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Melee</characteristic>
                <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Master-Crafted</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule name="Master Duelist" id="82a1-bce6-1e5f-bfbc" hidden="false">
              <description>As long as Mir&apos;san is in base contact with an enemy Independent Character model, he may chose to either gain an additional +1 Attack, or reduce the Attacks by -1 of a single Independent Character in base contact (to a minimum of 1) for that Assault Phase. Choose which will apply at the beginning of each Assault Phase before any attacks have been rolled by either side.</description>
            </rule>
            <rule name="Unfliching Resolve" id="1237-6deb-f288-e00e" hidden="false">
              <description>MirSan and any Space Marine unit he joins can choose to automatically pass or fail any Morale or Pinning tests they are called on to make.</description>
            </rule>
          </rules>
        </selectionEntry>
      </selectionEntries>
      <modifiers>
        <modifier type="add" value="Captain Pellas Mir&apos;san cannot be taken in a force less than 1500pts." field="error">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="force" childId="f96a-9b42-8e93-fd49" shared="true" includeChildSelections="true"/>
            <condition type="lessThan" value="1500" field="4ed5-2f92-9abc-2870" scope="force" childId="any" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
    </selectionEntry>

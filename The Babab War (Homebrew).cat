      <rules>
        <rule name="Lay in Wait" id="5935-2c0e-a794-90c1" hidden="false">
          <description>In a mission where Infiltrate is not allowed, the Tranquility Veterans may make a pre-game move of 6&quot; before the start of the first game turn.</description>
        </rule>
        <rule name="Corsair Predation" id="e5b2-bf73-7394-e0b7" hidden="false">
          <description>Tranquility Veterans may re-roll to hit any Eldar (or Dark Eldar) model in close combat.</description>
        </rule>
      </rules>

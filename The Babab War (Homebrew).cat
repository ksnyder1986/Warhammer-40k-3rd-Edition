              </characteristics>
            </profile>
            <profile name="Blood Biter" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon" hidden="false" id="13f7-ccc9-7882-4a0f">
              <characteristics>
                <characteristic name="Range" typeId="deb8-131d-bdcf-1376">Melee</characteristic>
                <characteristic name="S" typeId="24d8-2110-08fa-d844">5</characteristic>
                <characteristic name="AP" typeId="25ce-028f-0aae-2855">-</characteristic>
                <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Melee</characteristic>
                <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">On a to-hit roll of 6 automatically inflict a wound and ignore armour save. Other successful hits must roll to wound as normal. If Carnac rolls a 6 for Armour Penetration they then can roll an additional dice to determine the total Armour Penetration value.</characteristic>
              </characteristics>
            </profile>

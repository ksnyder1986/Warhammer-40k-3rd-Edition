      <entryLinks>
        <entryLink import="true" name="Command Squad" hidden="false" id="68ba-7e28-5364-ebbe" type="selectionEntry" targetId="bc53-c50d-f840-ebaa" sortIndex="4">
          <selectionEntryGroups>
            <selectionEntryGroup name="Extra Heavy Weapons" id="c5ad-211a-5ac4-7fd0" hidden="false" collective="false" import="true">
              <modifiers>
                <modifier type="set" value="1" field="91f8-2e30-2336-c8c9">
                  <conditionGroups>
                    <conditionGroup type="or">
                      <conditionGroups>

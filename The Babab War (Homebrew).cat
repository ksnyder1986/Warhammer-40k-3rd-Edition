              <modifiers>
                <modifier type="set" value="Thundershock" field="name"/>
                <modifier type="set" value="Master-crafted; If you roll a 1 to hit with a plasma weapon it has overheated and injured the model firing it. Make an armor save for the model, otherwise it will suffer a wound. Plasma weapons on vehicles are not affected by overheating." field="492d-1f80-b777-26f2"/>
              </modifiers>
            </infoLink>
            <infoLink name="Infiltrators" id="59be-2a6f-0b84-f396" hidden="false" type="rule" targetId="b4ea-750c-d9a4-e398"/>

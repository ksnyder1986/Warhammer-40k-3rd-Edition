          </infoLinks>
          <rules>
            <rule name="The Armour of Selket" id="47ef-ac62-9be0-c018" hidden="false">
              <description>The Armour of Selket is a suit of Artificer armour that incorporates a Psychic Hood. In addition, at the start of his turn Sevrin&apos;s 2+ armour save becomes a 2+ invulnerable save by passing a psychic test until the beginning of Sevrin&apos;s next turn.</description>
            </rule>
            <rule name="Master Psyker" id="26a9-ccce-c27a-d513" hidden="false">
              <description>Sevrin knows Smite, Weaken Resolve, and two random Minor Psychic Powers.</description>
            </rule>
            <rule name="Weaken Resolve" id="05d5-65d3-5046-f583" hidden="false">
              <description>Sevrin may attempt to use Weaken Resolve psychic power when an enemy unit with a model within 12&quot; of him has to take a Morale check. If he passes the Psychic test then the enemy unit must take is Morale Check using 3D6, rather than 2D6. This power may only be used once per player turn.</description>
            </rule>
          </rules>
        </selectionEntry>
      </selectionEntries>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="180"/>
      </costs>

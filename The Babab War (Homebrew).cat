    <selectionEntry type="unit" import="true" name="Chief Librarian Ahazra Redth" hidden="false" id="a940-a0e3-8eef-4a4e">
      <categoryLinks>
        <categoryLink targetId="a8a7-7a4b-5f7e-2138" id="a987-3d5c-3fd5-22cb" primary="true" name="HQ"/>
      </categoryLinks>
      <modifiers>
        <modifier type="add" value="Chief Librarian Ahazra Redth cannot be taken in a force less than 1500pts." field="error">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="force" childId="a940-a0e3-8eef-4a4e" shared="true" includeChildSelections="true"/>
            <condition type="lessThan" value="1500" field="4ed5-2f92-9abc-2870" scope="force" childId="any" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
      <selectionEntries>
        <selectionEntry type="model" import="true" name="Ahazra Redth" hidden="false" id="3a2b-fed3-a670-5325">
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="200"/>
          </costs>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="2431-5156-f240-e184-min"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="2431-5156-f240-e184-max"/>
          </constraints>
          <profiles>
            <profile name="Ahazra Redth" typeId="1e16-2bd8-7cad-379b" typeName="Unit" hidden="false" id="68cb-40ff-d6ef-7b6e">
              <characteristics>
                <characteristic name="WS" typeId="c704-6128-f143-935a">5</characteristic>
                <characteristic name="BS" typeId="7928-3a9b-6080-ed95">4</characteristic>
                <characteristic name="S" typeId="df03-6292-d3f5-f778">4</characteristic>
                <characteristic name="T" typeId="e5f6-94c4-de8c-5fa8">4</characteristic>
                <characteristic name="W" typeId="4dc2-c603-0bc5-0561">2</characteristic>
                <characteristic name="I" typeId="eeda-4fb4-901e-b70d">5</characteristic>
                <characteristic name="A" typeId="abbf-0d11-fd86-d938">3</characteristic>
                <characteristic name="Ld" typeId="f47e-b15a-8f58-703c">10</characteristic>
                <characteristic name="Sv" typeId="b309-5233-122f-82bb">3+</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Force Weapon" id="c9b4-dc52-60fb-19af" hidden="false" type="profile" targetId="e5ab-52f0-b14b-e93c"/>
            <infoLink name="Bolt Pistol" id="ce45-fcd2-29e7-db66" hidden="false" type="profile" targetId="e9ac-c779-51bb-3c9a"/>
            <infoLink name="Psychic Hood" id="4e16-dbc4-620f-a6de" hidden="false" type="rule" targetId="d637-ddb3-5ed3-bee8"/>
            <infoLink name="Purity Seals" id="4c41-df90-314d-402c" hidden="false" type="rule" targetId="8fca-253c-bbf8-9510"/>
            <infoLink name="Frag Grenades" id="fd67-4a79-e278-b2cf" hidden="false" type="profile" targetId="9dd4-e950-2419-5934"/>
            <infoLink name="Krak Grenades" id="6765-8014-2daf-d7a9" hidden="false" type="profile" targetId="9c1b-bf93-059b-27f5"/>
            <infoLink name="Smite" id="559e-6828-30e1-0f7b" hidden="false" type="profile" targetId="c4fd-c9a0-298c-1f66"/>
            <infoLink name="Independent Character" id="407c-88a1-ca2d-2803" hidden="false" type="rule" targetId="4a60-7f7e-c37f-a4d6"/>
          </infoLinks>
          <rules>
            <rule name="Whispers of the Wind" id="a8ea-7fcc-b1f0-698b" hidden="false">
              <description>If Ahazra is part of the army, then the Mantis Warriors can force his opponent to re-roll their dice to see who gets first turn. They also suffer a -1 Penalty for the rolls to see if Reserves arrive.</description>
            </rule>
            <rule name="Talisman of Sundered Souls" id="619e-0693-2641-7663" hidden="false">
              <description>This gorget studded with Eldar wraithbone grants Redth a 5+ Invunerable save and allows him to re-roll a single Psychic Test a turn.</description>
            </rule>
            <rule name="Mirage" id="550f-b8a7-9365-db4a" hidden="false">
              <description>At the start of the Mantis Warriors movement phase Ahazra may make a psychic test. If passed he and any squad he has joined and/or vehicle he is transported in counts receives a 5+ Cover Save and any enemies wishing to shoot at them must do so using the Night Fighting mission rule (searchlights have no effect against Mirage). This continues until the start of Ahazra&apos;s next turn.</description>
            </rule>
          </rules>
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Minor Psychic Power" hidden="false" id="704f-4d79-e22c-02ed" collective="false">
              <infoLinks>

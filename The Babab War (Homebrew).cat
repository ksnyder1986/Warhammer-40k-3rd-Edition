        <infoLink name="Deep Strike" id="f5d5-0df6-0672-08e0" hidden="false" type="rule" targetId="5715-6219-5059-9bcf"/>
      </infoLinks>
      <rules>
        <rule name="Will of the Shade Lord" id="1690-6422-b6c2-4134" hidden="false">
          <description>Red Brethren may re-roll any failed Pinning or Morale Checks.


In addition, no Independent Characters, except for Tyberos the Red Wake, may join a Red Brethren Terminator Squad.</description>
        </rule>
        <rule name="Circling Predators" id="21a7-ed08-73d6-4a46" hidden="false">
          <description>In a turn in which a Red Brethren Terminator Squad Deep Strikes onto the battlefield, they may move D3&quot; towards the nearest enemy unit during the assault phase. If they move into base contact, they count as being engaged in close combat and may fight in melee that turn, but they do not count as charging.</description>
        </rule>
      </rules>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="998a-1987-79e6-f37a" includeChildSelections="true"/>
      </constraints>
    </selectionEntry>

      <rules>
        <rule name="Atomantic Shielding" id="0388-5075-3ad3-2da5" hidden="false">
          <description>The Hecaton Contemptor Dreadnought has a 5+ Invulnerable Save against any Glancing or Penetrating hits caused during the shooting phase. In addition, count any roll of a 4, 5 or 6 on the Penetrating Hit Damage Chart as a 6 instead.</description>
        </rule>
        <rule name="Irreplaceable Loss" id="d363-7103-8651-57aa" hidden="false">
          <description>If a Minotaurs Hecaton Contemptor Dreadnought is Immobilized or has a weapon destroyed by the end of the battle it awards the opponent full victory points. If it is destroyed it awards the opponent double its victory points instead.</description>
        </rule>
      </rules>
    </selectionEntry>

          <infoLinks>
            <infoLink name="Terminator Armour" id="8634-a61f-35ee-dacb" hidden="false" type="rule" targetId="fe7a-62df-712a-5bc5"/>
            <infoLink name="Iron Halo" id="65f1-1706-0a4c-06fb" hidden="false" type="rule" targetId="c214-19e6-edea-0f81"/>
            <infoLink name="Purity Seals" id="924d-87a9-b335-3b56" hidden="false" type="rule" targetId="8fca-253c-bbf8-9510"/>
            <infoLink name="Heavy Flamer" id="6ddc-ae3a-35db-7f8f" hidden="false" type="profile" targetId="6d36-2c09-dfc3-f257"/>
            <infoLink name="Lightning Claw" id="09b0-f30b-b651-0357" hidden="false" type="profile" targetId="c7a3-7006-5226-8181">
              <modifiers>
                <modifier type="set" value="The Ghost Razors" field="name"/>
                <modifier type="set" value="User +1" field="24d8-2110-08fa-d844"/>
                <modifier type="set" value="May re-roll any failed wounds. Any successful Invulnerable Saves made against wounds from the Ghost Razors must be re-rolled." field="492d-1f80-b777-26f2"/>
              </modifiers>
            </infoLink>
            <infoLink name="Independent Character" id="39c4-cf28-49da-2558" hidden="false" type="rule" targetId="4a60-7f7e-c37f-a4d6"/>
          </infoLinks>
          <rules>
            <rule name="No Retreat" id="5713-cb6a-74aa-7830" hidden="false">
              <description>If Huron is in the Army, any units selected from Codex: Space Marines, Codex: The Badab War, or units that count as being selected from Codex: Space Marines in the Tyrant&apos;s Legion count as being Stubborn as long as he is on the table.
The unit will automatically pass any Morale checks they have to take, even if faced by a situation or opponent that would normally cause them to automatically fail. Note that they still must test for pinning as normal.</description>
            </rule>
            <rule name="Big Guns Never Tire" id="f568-3200-2d91-da6c" hidden="false">
              <description>Once per battle, Huron may select an enemy unit within line of sight and call down a barrage. Place an Ordnance template over the unit and then scatter it 2D6&quot;. If a hit is rolled, scatter it the lower of the D6s in the direction of the small arrow. Any model under the template receives a S9, AP3 hit.</description>
            </rule>
          </rules>
        </selectionEntry>
      </selectionEntries>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="7ff5-ee26-b841-ec8c" includeChildSelections="true"/>
      </constraints>
      <modifiers>
        <modifier type="add" value="Chapter Master Lufgt Huran cannot be taken in a force less than 1500pts." field="error">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="force" childId="2839-599d-5f60-ecbf" shared="true" includeChildSelections="true"/>
            <condition type="lessThan" value="1500" field="4ed5-2f92-9abc-2870" scope="force" childId="any" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="250"/>
      </costs>

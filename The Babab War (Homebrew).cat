            </profile>
            <profile name="Malice - Suppressive Fire" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon" hidden="false" id="fb9c-9868-f603-d3cb">
              <characteristics>
                <characteristic name="Range" typeId="deb8-131d-bdcf-1376">36&quot;</characteristic>
                <characteristic name="S" typeId="24d8-2110-08fa-d844">4</characteristic>
                <characteristic name="AP" typeId="25ce-028f-0aae-2855">4</characteristic>
                <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Heavy 4</characteristic>
                <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Rending; Always wounds on 4+, use Str for vehicle penetration rolls; Forced pinning check with -1 Ld modifier.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Iron Halo" id="a80a-d010-8424-562a" hidden="false" type="rule" targetId="c214-19e6-edea-0f81"/>
            <infoLink name="Purity Seals" id="8a8e-21e7-5877-a892" hidden="false" type="rule" targetId="8fca-253c-bbf8-9510"/>
            <infoLink name="Power Weapon" id="07d5-989e-1d43-ed67" hidden="false" type="profile" targetId="5774-7187-2616-dd8a"/>
            <infoLink name="Bolt Pistol" id="dc29-88de-8fd9-ffaa" hidden="false" type="profile" targetId="e9ac-c779-51bb-3c9a"/>
            <infoLink name="Frag Grenades" id="e90b-2d8c-a29d-ecfa" hidden="false" type="profile" targetId="9dd4-e950-2419-5934"/>
            <infoLink name="Krak Grenades" id="d3c6-e780-894b-40a9" hidden="false" type="profile" targetId="9c1b-bf93-059b-27f5"/>
            <infoLink name="Independent Character" id="da37-6f7d-226f-5f60" hidden="false" type="rule" targetId="4a60-7f7e-c37f-a4d6"/>
          </infoLinks>
          <rules>
            <rule name="Cunning Strategist" id="0383-8b1d-8239-a94b" hidden="false">
              <description>If Issodon is present in your army the enemy reserve rolls suffer a -1 penalty.</description>
            </rule>
            <rule name="Infiltrate, Isolate and Destroy" id="a714-1d1c-cc2f-703d" hidden="false">
              <description>If your army contains Lias Issodon, you may select a single enemy unit which is either an enemy squad, monstrous creature or vehicle that is present on the battlefield at the beginning of the game as the victim of assassination or sabotage. After any infiltrator or scout moves are made, but before the game begins, if a squad or monstrous creature is the chosen unit, it suffers D6 wounds distributed as shooting (AP - ). If the chosen unit was a vehicle, roll a D6. On a 1-3 the Vehicle is Shaken, on a 4-5 it is Stunned, on a 6 it is immobilized. Independent characters cannot be targeted by this attack.</description>
            </rule>
          </rules>
        </selectionEntry>
      </selectionEntries>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="175"/>
      </costs>

        <selectionEntry type="model" import="true" name="Retaliator Enforcer" hidden="false" id="ff05-2b64-1ae6-bd3f">
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="30"/>
          </costs>
          <constraints>
            <constraint type="max" value="3" field="selections" scope="parent" shared="true" id="a9fc-7bc6-c7a5-b370"/>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="a4ae-33b6-8bb1-a7e2"/>
          </constraints>
          <profiles>
            <profile name="Retaliator Enforcer" typeId="1e16-2bd8-7cad-379b" typeName="Unit" hidden="false" id="4a52-4cb1-cbcd-308d">
              <characteristics>
                <characteristic name="WS" typeId="c704-6128-f143-935a">4</characteristic>
                <characteristic name="BS" typeId="7928-3a9b-6080-ed95">5</characteristic>
                <characteristic name="S" typeId="df03-6292-d3f5-f778">4</characteristic>
                <characteristic name="T" typeId="e5f6-94c4-de8c-5fa8">4</characteristic>
                <characteristic name="W" typeId="4dc2-c603-0bc5-0561">1</characteristic>
                <characteristic name="I" typeId="eeda-4fb4-901e-b70d">4</characteristic>
                <characteristic name="A" typeId="abbf-0d11-fd86-d938">2</characteristic>
                <characteristic name="Ld" typeId="f47e-b15a-8f58-703c">9</characteristic>
                <characteristic name="Sv" typeId="b309-5233-122f-82bb">3+</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <entryLinks>
            <entryLink import="true" name="Space Marine Armory" hidden="false" id="008e-35cf-956d-84e8" type="selectionEntryGroup" targetId="bfc9-22b8-1379-3112"/>
          </entryLinks>
          <rules>
            <rule name="Attachment" id="039f-8b62-116b-419d" hidden="false">
              <description>Each Enforcer must be allocated to lead one of the following units: Legion Auxilia Cohort, Auxilia Armsmen Cadre, Auxilia Fire Support Cohort or Auxilia Heavy Ordnance Battery.</description>
            </rule>
            <rule name="Astral Claws First" id="cd06-0b16-d33f-bc2f" hidden="false">
              <description>As an Astral Claws Space Marine, a Enforcer still benefits from the Stubborn special rule, but it does not interact differently if he has joined an Auxilia unit. He does not suffer (or benefit) from the Intractable and The Strong and Strongest Alone rules.</description>
            </rule>
            <rule name="The Tyrant&apos;s Will" id="c9af-3355-09d2-7957" hidden="false">
              <description>If an attached unit containing a Retaliator Enforcer fails a Morale Check from shooting casualties or losing a combat, remove a single model then reroll the test. If the unit fails again, the entire unit (including the Enforcer) falls back as usual.</description>
            </rule>
            <rule name="Huron&apos;s Executioners" id="07ac-f725-a686-84ba" hidden="false">
              <description>A Retaliator Enforcer may reroll to-hit rolls in the first round of a combat against Space Marines.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink name="Stubborn" id="7c31-d230-8a1b-afc0" hidden="false" type="rule" targetId="1eb7-6961-7e16-d0b6"/>
          </infoLinks>
        </selectionEntry>
      </selectionEntries>
    </selectionEntry>

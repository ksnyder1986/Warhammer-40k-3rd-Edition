          </infoLinks>
          <rules>
            <rule name="Masterwork Storm Shield" id="aea3-38fc-478c-0a50" hidden="false">
              <description>Allows a 3+ invulnerable save against one opponent per turn in close combat. Cannot be combined with Rosarius or Iron Halo saves</description>
            </rule>
            <rule name="Dark Fury" id="f1f7-2a6e-06f9-61fa" hidden="false">
              <description>Both Moloc and any Space Marine squad he joined automatically passes all Pinning and Morale Checks they are required to make. In addition, they count as always being equipped with frag grenades when determining initiative in the first round of combat.</description>
            </rule>
            <rule name="Hound of the High Lords" id="ac96-dbba-55a1-daeb" hidden="false">
              <description>Any HQ choices that Moloc personally removes the final wound from (or in the case of HQ vehicles, destroys it) counts as double Victory Points at the end of the battle.</description>
            </rule>
          </rules>
        </selectionEntry>

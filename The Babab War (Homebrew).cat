          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Stalkers" hidden="false" id="92df-0ef6-e117-20ca">
              <rules>
                <rule name="Stalker" id="f049-f484-2410-55a3" hidden="false">
                  <description>The marauders gain Move Through Cover and Night Vision special rules. Additional all marauders gain access to Sniper Rifles.</description>
                </rule>
                <rule name="Night Vision" id="71c0-0f7a-8ad1-3e5d" hidden="false">
                  <description>Re-roll the dice when rolling to determine how far the unit can see.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink name="Move Through Cover" id="ecdd-a230-1306-934c" hidden="false" type="rule" targetId="3a88-67df-4004-176b"/>
              </infoLinks>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Murder Cultists" hidden="false" id="1b36-6991-6235-56dd">
              <rules>
                <rule name="Murder Cultists" id="82ad-08d0-5900-8c72" hidden="false">
                  <description>The marauders gain the Furious Charge and Infiltrate special rules.</description>
                </rule>
                <rule name="Furious Charge" id="bcfe-6139-98c2-6c26" hidden="false">
                  <description>When the unit charges, all models are at +1 I and +1 S</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink name="Infiltrators" id="64ff-1cf5-7461-6154" hidden="false" type="rule" targetId="b4ea-750c-d9a4-e398"/>
              </infoLinks>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Hereteks" hidden="false" id="a2f5-1987-cbf8-bf06">
              <rules>
                <rule name="Hereteks" id="d65c-71c0-608f-d342" hidden="false">
                  <description>The marauders&apos; armour save is increased to 4+ and the entire unit gains Krak Grenades. Additionally, they gain access to purchase Plasma Guns.</description>
                </rule>
              </rules>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <selectionEntries>

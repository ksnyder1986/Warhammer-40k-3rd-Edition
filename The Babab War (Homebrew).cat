              <modifiers>
                <modifier type="set" value="Master-Crafted Thunder Hammer" field="name"/>
              </modifiers>
            </infoLink>
            <infoLink name="Independent Character" id="3e7b-7891-440c-f6b2" hidden="false" type="rule" targetId="4a60-7f7e-c37f-a4d6"/>
          </infoLinks>
          <rules>
            <rule name="Purge the Weak" id="ea4b-cfe9-ffdb-ff0c" hidden="false">
              <description>If Vaylund Cal is part of the army, one appropriately modelled devastator squad may be upgraded with cybernetic augmentations for 10pts per model. These Devastators gain +1 Toughness, are immune to all Morale Checks and gain the Bionics upgrade at no additional cost.</description>
            </rule>
            <rule name="Opus Machina" id="6fba-ab63-5645-895a" hidden="false">
              <description>Vaylund must be modelled on a 40mm or larger base and counts as two models for transport purposes.</description>
            </rule>
            <rule name="Iron Thane" id="788d-35e9-762d-e4e3" hidden="false">
              <description>If Vaylund Cal attempts to repair a Space Marine vehicle with one of his Servo-Arms it is repaired on a 3+ instead of only a 6.</description>
            </rule>
            <rule name="Indefatigable" id="ed2e-031e-e219-6252" hidden="false">
              <description>Vaylund Cal and any unit he joins automatically pass any Morale and Leadership tests they are required to take.</description>
            </rule>
            <rule name="Commander of Legend" id="ae2d-386c-e25e-d9db" hidden="false">
              <description>Vaylund Cal counts as a Chapter Master for the Proud and the Arrogant Badab War special rule.</description>
            </rule>
          </rules>
        </selectionEntry>
      </selectionEntries>
    </selectionEntry>
